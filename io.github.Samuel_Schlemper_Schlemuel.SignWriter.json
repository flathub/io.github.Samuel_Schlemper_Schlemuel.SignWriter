{
    "id" : "io.github.Samuel_Schlemper_Schlemuel.SignWriter",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "signwriter",
    "finish-args" : [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "SignWriter",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/Samuel-Schlemper-Schlemuel/SignWriter.git",
                    "commit": "e7f94cebd1fa4d1dbf05f959ac372ccc44f3e9cc"
                }
            ]
        }
    ]
}
